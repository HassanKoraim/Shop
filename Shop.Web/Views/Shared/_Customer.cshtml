@using Microsoft.AspNetCore.Http
@using myshop.Utilities
@inject IHttpContextAccessor httpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="Find amazing products with good prices at myShop." />
    <meta name="author" content="myShop" />
    <title>myShop - Premium eCommerce</title>

    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />

    <link href="~/customer/css/styles.css" rel="stylesheet" />
</head>
<body>

    <div class="bg-primary text-white text-center py-2 small fw-bold">
        🚚 Free shipping on all orders over $50! Shop Now.
    </div>

    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
        <div class="container px-4 px-lg-5">

            <a class="navbar-brand fw-bold fs-4 text-dark" asp-area="Customer" asp-controller="Home" asp-action="Index">
                <i class="bi bi-bag-heart-fill text-primary"></i> myShop
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    @if (User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole(SD.AdminRole))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-semibold text-danger" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-semibold" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    My Settings
                                </a>
                                <ul class="dropdown-menu border-0 shadow" aria-labelledby="navbarDropdown">
                                    <li><a class="dropdown-item" asp-area="Customer" asp-controller="Cart" asp-action="Index"><i class="bi bi-box-seam me-2"></i>My Orders</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" href="/Identity/Account/Manage"><i class="bi bi-person-gear me-2"></i>Edit Profile</a></li>
                                </ul>
                            </li>
                        }
                    }
                </ul>

                <div class="d-flex align-items-center gap-3">
                    <partial name="_LoginPartial" />

                    @if (User.Identity.IsAuthenticated && !User.IsInRole(SD.AdminRole))
                    {
                        <a asp-area="Customer" asp-controller="Cart" asp-action="Index" class="btn btn-primary rounded-pill px-3 shadow-sm d-flex align-items-center">
                            <i class="bi bi-cart3 me-1"></i>
                            Cart
                            <span class="ms-1">
                                @await Component.InvokeAsync("ShoppingCart")
                            </span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <header class="bg-dark py-5 text-center text-white position-relative" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?auto=format&fit=crop&w=1500&q=80') center/cover no-repeat;">
        <div class="container px-4 px-lg-5 my-5">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <h1 class="display-4 fw-bolder mb-3">Welcome to myShop</h1>
                    <p class="lead fw-normal text-white-50 mb-4">Discover curated trends, fast shipping, and unbeatable prices on premium items.</p>
                    <a href="#shop-section" class="btn btn-primary btn-lg rounded-pill px-4 shadow">Start Shopping <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
            </div>
        </div>
    </header>

    <main id="shop-section" class="min-vh-100 py-5 bg-light">
        @RenderBody()
    </main>

    <footer class="py-5 bg-dark">
        <div class="container">
            <p class="m-0 text-center text-white-50">Copyright &copy; myShop @DateTime.Now.Year. All Rights Reserved.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/customer/js/scripts.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>