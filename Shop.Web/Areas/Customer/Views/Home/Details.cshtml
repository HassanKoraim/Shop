@model ShoppingCart
@{
    ViewBag.PageTitle = "Product Management";
    ViewBag.CardTitle = "Details Product";
}

<form method="post" asp-action="Details">
    <section class="py-5">
        <div class="container px-4 px-lg-5 my-5">
            <div class="row gx-4 gx-lg-5 align-items-center">

                <input asp-for="ProductId" hidden />

                <div class="col-md-6">
                    <div class="photo-container">
                        <img class="zoom-photo" src="@Model.Product.Img" alt="@Model.Product.Name" />
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="small mb-2 text-uppercase text-muted fw-bold">@Model.Product.Category.Name</div>
                    <h1 class="display-5 fw-bolder text-dark mb-3">@Model.Product.Name</h1>

                    <div class="fs-4 mb-4">
                        @if (Model.Product.Price < 45) // Example logical check for sales
                        {
                            <span class="text-muted text-decoration-line-through me-2">$45.00</span>
                        }
                        <span class="text-primary fw-bold">@Model.Product.Price.ToString("C")</span>
                    </div>

                    <p class="lead text-secondary mb-4">@Model.Product.Description</p>

                    <div class="d-flex align-items-center gap-2">
                        <div class="form-floating" style="width: 100px;">
                            <input asp-for="Count" class="form-control text-center" id="inputQuantity" type="number" min="1" value="1" />
                            <label for="inputQuantity">Qty</label>
                        </div>

                        <button class="btn btn-primary btn-lg flex-shrink-0 rounded-pill px-4 shadow-sm" type="submit">
                            <i class="bi-cart-fill me-2"></i> Add to cart
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </section>
</form>

<hr class="my-5 opacity-25" />

<section class="py-5 bg-light">
    <div class="container px-4 px-lg-5">
        <h3 class="fw-bolder mb-4 text-dark"><i class="bi bi-tag-fill text-primary me-2"></i>Related products</h3>

        <div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">

            <div class="col mb-5">
                <div class="card h-100 shadow-sm border-0">
                    <img class="card-img-top" src="https://dummyimage.com/450x300/dee2e6/6c757d.jpg" alt="Related" style="height: 200px; object-fit: cover;" />
                    <div class="card-body p-4">
                        <div class="text-center">
                            <h6 class="fw-bolder text-dark">Fancy Product</h6>
                            <span class="text-primary fw-bold">$40.00</span>
                        </div>
                    </div>
                    <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                        <div class="text-center">
                            <a class="btn btn-outline-primary btn-sm rounded-pill w-100" href="#">View Details</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col mb-5">
                <div class="card h-100 shadow-sm border-0 position-relative">
                    <div class="badge bg-danger text-white position-absolute" style="top: 0.5rem; right: 0.5rem">Sale</div>
                    <img class="card-img-top" src="https://dummyimage.com/450x300/dee2e6/6c757d.jpg" alt="Related" style="height: 200px; object-fit: cover;" />
                    <div class="card-body p-4">
                        <div class="text-center">
                            <h6 class="fw-bolder text-dark">Special Item</h6>
                            <div class="d-flex justify-content-center small text-warning mb-2">
                                <i class="bi-star-fill"></i><i class="bi-star-fill"></i><i class="bi-star-fill"></i><i class="bi-star-fill"></i><i class="bi-star-fill"></i>
                            </div>
                            <span class="text-muted text-decoration-line-through me-1">$20.00</span>
                            <span class="text-danger fw-bold">$18.00</span>
                        </div>
                    </div>
                    <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                        <div class="text-center">
                            <a class="btn btn-outline-primary btn-sm rounded-pill w-100" href="#">View Details</a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>