@model ProductVM
@{
    ViewBag.PageTitle = "Product Management";
    ViewBag.CardTitle = "Create Product";
}
<div class="row">
    <div class="col-md-4">
    <form method="post" asp-action="Create" asp-controller="Product" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        @* <div class="mb-3">
            <label asp-for="Id"></label>
            <input asp-for="Id" class="form-control" />
            <span asp-validation-for="Id" class="text-danger"></span>
        </div> *@
        <div class="form-group">
            <label asp-for="Product.Name"></label>
            <input asp-for="Product.Name" class="form-control" />
            <span asp-validation-for="Product.Name" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Product.Description"></label>
            <textarea id="default-editor" asp-for="Product.Description" class="form-control"></textarea>
            <span asp-validation-for="Product.Description" class="text-danger"></span>
        </div>
            <div class="form-group">
            <label asp-for="Product.Price"></label>
            <input asp-for="Product.Price" class="form-control" />
            <span asp-validation-for="Product.Price" class="text-danger"></span>
        </div>
            <div class="form-group">
            <label asp-for="Product.Img"></label>
            @* id="imgFile" *@
                <input type="file" name="file" id="imgFile" class="form-control" onchange="fillimg(event);" />
            <span asp-validation-for="Product.Img" class="text-danger"></span>
        </div>
            <div class="form-group">
            <label asp-for="Product.CategoryId"></label>
            <select asp-for="Product.CategoryId" asp-items="Model.CategoryList" class="form-control">
                <option disapled value="">---- Select Category</option>
            </select>
            <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
        </div>
        <div class=" form-group">
                <button class="btn btn-success" type="submit">Submit</button>
        </div>
        <a class="btn btn-danger" asp-action="Index" asp-controller="Category">Go To Index</a>
    </form>
    </div>
    <div class="col-md-4">
        <div class="container">
            <img id="ImagePreview" src="@Model.Product.Img" width="300" height="300" />
            @* @Url.Content("~/images/products/" + Model.Product.Img) *@
        </div>
    </div>
</div>
@section scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
          tinymce.init({
        selector: 'textarea#default-editor'
           });
    </script>
    <script>
        var fillimg = function(event){
            const file = event.target.files[0];
             if (file != null && file.type.startsWith("image/")) {
                  var imgholder = document.getElementById("ImagePreview");
                  imgholder.src = URL.createObjectURL(file);
             }
        }
           
        }
    </script>
}